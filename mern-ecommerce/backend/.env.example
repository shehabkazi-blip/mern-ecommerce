# Server
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# MongoDB (use MongoDB Atlas for production)
MONGO_URI=mongodb://127.0.0.1:27017/mern_ecommerce

# Auth
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=30d
COOKIE_EXPIRES_DAYS=30

# Stripe (optional - test mode keys, leave blank to disable card payments)
STRIPE_SECRET_KEY=

# AWS (used for S3 database backups from the EC2 instance)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BACKUP_BUCKET=my-mern-ecommerce-backups

# First admin account, created automatically by the seeder
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!
